{
  "version": "0.1.0",
  "npmClient": "npm",
  "useWorkspaces": true,
  "packages": [
    "packages/*"
  ],
  "command": {
    "publish": {
      "conventionalCommits": true,
      "message": "chore(release): publish %s"
    },
    "version": {
      "allowBranch": "main",
      "message": "chore(release): version %s"
    }
  }
}